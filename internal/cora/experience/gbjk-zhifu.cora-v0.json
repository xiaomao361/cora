        "class": "OrderSplitUtil",
        "method": "splitQuotaSubOrders",
        "message_contains": [
          "[额度支付-订单拆单开始处理]"
        ]
      }
    },
    {
      "id": "ig_49",
      "decision": "ignore",
      "category": "额度支付拆单结束日志",
      "reason": "额度支付拆单结束且无需处理属于正常流程日志",
      "match": {
        "class": "OrderSplitUtil",
        "method": "splitQuotaSubOrders",
        "message_contains": [
          "[额度支付-订单拆单结束]",
          "无需处理"
        ]
      }
    },
    {
      "id": "ig_50",
      "decision": "ignore",
      "category": "订单支付成功后处理日志",
      "reason": "订单支付成功后处理属于成功态INFO日志，不作为异常",
