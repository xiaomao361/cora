        "method": "payAllSuccessAfter",
        "message_contains": [
          "网药订单支付成功后处理"
        ]
      }
    },
    {
      "id": "ig_51",
      "decision": "ignore",
      "category": "订单退款受理赔限制",
      "reason": "订单已进入理赔流程后无法退款，属于业务规则限制",
