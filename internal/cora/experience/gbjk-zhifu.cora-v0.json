{
  "schema_version": "cora.experience-pack.v1",
  "product_line": "gbjk-zhifu",
  "version": "cora-gbjk-v0.1.0",
  "source": {
    "type": "validated_rule_baseline",
    "reviewed_at": "2026-07-13"
  },
  "default_decision": "observe",
  "priority_order": [
    "attention",
    "observe",
    "ignore"
  ],
  "rules": [
    {
      "id": "ig_01",
      "decision": "ignore",
      "category": "业务校验-保单责任不存在",
      "reason": "路由找不到保单责任信息，无异常栈，大量重复",
      "match": {
        "class": "RouterServiceImpl",
        "method": "route"
      }
    },
    {
      "id": "ig_02",
      "decision": "ignore",
      "category": "三方数据-健康档案员工不存在",
      "reason": "健康档案推送时员工不存在",
      "match": {
        "class": "HealthPsychologyServiceImpl"
      }
    },
    {
      "id": "ig_03",
      "decision": "ignore",
      "category": "客户端-JWT异常",
      "reason": "JWT过期或无效，客户端重新登录即可",
      "match": {
        "class": "RouterServiceImpl",
        "method": "checkAccess"
      }
    },
    {
      "id": "ig_04",
      "decision": "ignore",
      "category": "客户端-Token异常",
      "reason": "Token签名不匹配或过期，客户端问题",
      "match": {
        "class": "TokenUserService",
        "method": "getDataScope"
      }
    },
    {
      "id": "ig_05",
      "decision": "ignore",
      "category": "用户输入-支付密码错误",
      "reason": "用户输错支付密码",
      "match": {
        "class": "TradeOrdersServiceImpl",
        "method": "validatePayPwdRetry"
      }
    },
    {
      "id": "ig_06",
      "decision": "ignore",
      "category": "业务校验-商品不存在",
      "reason": "商品信息同步延迟",
      "match": {
        "class": "OnlineOrderSourceExecuteServiceImpl",
        "method": "verifyPrePayOrder"
      }
    },
    {
      "id": "ig_07",
      "decision": "ignore",
      "category": "三方不可用-订单回调失败",
      "reason": "订单回调三方服务不可达",
      "match": {
        "class": "OrderNotifyService",
        "method": "handleNotify"
      }
    },
    {
      "id": "ig_08",
      "decision": "ignore",
      "category": "状态机-重复取消",
      "reason": "订单已取消后定时任务再次取消",
      "match": {
        "class": "BaseStateMachine",
        "message_contains": [
          "状态机转换失败"
        ]
      }
    },
    {
      "id": "ig_09",
      "decision": "ignore",
      "category": "状态机-执行异常",
      "reason": "状态机转换失败的后续异常",
      "match": {
        "class": "OrderExecuteService",
        "message_contains": [
          "状态机转换失败"
        ]
      }
    },
    {
      "id": "ig_10",
      "decision": "ignore",
      "category": "业务配置-TPA已禁用",
      "reason": "理赔结算TPA功能已禁用",
      "match": {
        "class": "SettleClaimCasesServiceImpl",
        "message_contains": [
          "结算推送失败",
          "结算深度失败"
        ]
      }
    },
    {
      "id": "ig_11",
      "decision": "ignore",
      "category": "启动-端口占用",
      "reason": "xxl-job端口被占用",
      "match": {
        "class": "EmbedServer",
        "message_contains": [
          "xxl-job remoting server error"
        ]
      }
    },
    {
      "id": "ig_12",
      "decision": "ignore",
      "category": "业务校验-收款单金额超限",
      "reason": "财务对账金额校验失败或导入异常",
      "match": {
        "class_contains": [
          "ReceiptDetailServiceImpl",
          "ReceiptServiceImpl"
        ],
        "message_contains": [
          "收款单",
          "批量导入"
        ]
      }
    },
    {
      "id": "ig_13",
      "decision": "ignore",
      "category": "客户端-登录注册异常",
      "reason": "用户登录、注册、设置密码等客户端操作失败",
      "match": {
        "class": "GlobalExceptionHandler",
        "message_contains": [
          "/login/",
          "/member/setPayPassword"
        ]
      }
    },
    {
      "id": "ig_14",
      "decision": "ignore",
      "category": "三方不可用-文件上传失败",
      "reason": "文件上传服务不可达",
      "match": {
        "class": "GlobalExceptionHandler",
        "message_contains": [
          "/inner/uploadFileInner"
        ]
      }
    },
    {
      "id": "ig_15",
      "decision": "ignore",
      "category": "网关鉴权-未授权请求",
      "reason": "网关未授权请求与探测流量，不作为运维关注主目标",
      "match": {
        "class": "ServletUtil",
        "method": "unauthorizedResponse",
        "message_contains": [
          "[鉴权异常处理]请求路径:"
        ]
      }
    },
    {
      "id": "ig_16",
      "decision": "ignore",
      "category": "认证失败-用户凭证问题",
      "reason": "认证失败属于用户凭证或登录问题，默认不作为运维异常",
      "match": {
        "class": "AuthenticationBaseProvider",
        "method": "authenticate",
        "message_contains": [
          "problem in authenticate"
        ]
      }
    },
    {
      "id": "ig_17",
      "decision": "ignore",
      "category": "三方回调-调试响应噪音",
      "reason": "Forest 调试响应行是下游失败的伴生噪音，不单独关注",
      "match": {
        "class": "DefaultLogHandler",
        "method": "info",
        "message_contains": [
          "[Forest] Response: [Network Error]"
        ]
      }
    },
    {
      "id": "ig_18",
      "decision": "ignore",
      "category": "医保业务-无责任数据",
      "reason": "医保责任数据缺失属于业务数据问题，默认忽略",
      "match": {
        "class": "YbReimburseTaskServiceImpl",
        "method": "getValidCardYbaVo",
        "message_contains": [
          "无任何公账责任数据"
        ]
      }
    },
    {
      "id": "ig_19",
      "decision": "ignore",
      "category": "前端账号-换绑手机号异常",
      "reason": "换绑手机号接口异常默认按用户操作或前端流程异常处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/member/replacePhone"
        ]
      }
    },
    {
      "id": "ig_20",
      "decision": "ignore",
      "category": "前端账号-手机号验证码异常",
      "reason": "手机号验证码相关接口异常默认按前端或用户流程问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/member/getCustomerPhoneCode",
          "/member/getPhoneCode",
          "/member/verificationReplacePhoneCode"
        ]
      }
    },
    {
      "id": "ig_21",
      "decision": "ignore",
      "category": "订单创建-断言异常",
      "reason": "提交创建订单断言异常当前按业务噪声处理，不进入运维关注面",
      "match": {
        "class": "TradeOrdersServiceImpl",
        "method": "submitUserOrder",
        "message_contains": [
          "断言异常"
        ]
      }
    },
    {
      "id": "ig_22",
      "decision": "ignore",
      "category": "现金支付-断言异常",
      "reason": "现金支付断言异常当前按业务噪声处理",
      "match": {
        "class": "UserOrderServiceImpl",
        "method": "payCash",
        "message_contains": [
          "断言异常"
        ]
      }
    },
    {
      "id": "ig_23",
      "decision": "ignore",
      "category": "额度试算-断言异常",
      "reason": "额度试算断言异常当前按业务噪声处理",
      "match": {
        "class": "UserOrderServiceImpl",
        "method": "defaultPolicyQuotaTrial",
        "message_contains": [
          "断言异常"
        ]
      }
    },
    {
      "id": "ig_24",
      "decision": "ignore",
      "category": "订单MQ发送日志",
      "reason": "订单MQ发送开始/成功日志误入异常集合，直接忽略",
      "match": {
        "class": "TradeOrdersServiceImpl",
        "method": "sendOrderMq",
        "message_contains": [
          "订单创建发送MQ消息"
        ]
      }
    },
    {
      "id": "ig_25",
      "decision": "ignore",
      "category": "事务日志切面输出",
      "reason": "事务日志切面输出属于调试/审计信息，不作为运维异常",
      "match": {
        "class": "TransactionLogAspect",
        "message_contains": [
          "事务日志切面"
        ]
      }
    },
    {
      "id": "ig_26",
      "decision": "ignore",
      "category": "审计SQL调试日志",
      "reason": "系统审计SQL调试输出不作为异常处理",
      "match": {
        "class": "S.insert",
        "method": "debug",
        "message_contains": [
          "==> Parameters:"
        ]
      }
    },
    {
      "id": "ig_27",
      "decision": "ignore",
      "category": "订单更新SQL调试日志",
      "reason": "订单更新SQL调试输出不作为异常处理",
      "match": {
        "class": "T.updateById",
        "method": "debug",
        "message_contains": [
          "==> Parameters:"
        ]
      }
    },
    {
      "id": "ig_28",
      "decision": "ignore",
      "category": "网关响应式丢弃噪音",
      "reason": "Reactor onErrorDropped 默认噪音，默认忽略",
      "match": {
        "class": "Operators",
        "method": "error",
        "message_contains": [
          "onErrorDropped"
        ]
      }
    },
    {
      "id": "ig_29",
      "decision": "ignore",
      "category": "心理报告推送异常",
      "reason": "心理报告推送路径异常当前按低优先级业务问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/inner/psychologyReport/addPsychologyReport"
        ]
      }
    },
    {
      "id": "ig_30",
      "decision": "ignore",
      "category": "用户卡查询异常",
      "reason": "用户卡与扣减明细查询路径异常当前按低优先级业务问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/inner/userCard/openGetUserValidCardPolicyList",
          "/inner/cardDetail/deductionAmount"
        ]
      }
    },
    {
      "id": "ig_31",
      "decision": "ignore",
      "category": "商品详情查询异常",
      "reason": "商品详情查询接口异常当前按低优先级业务问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/inner/goods/queryGoodsDetailsList"
        ]
      }
    },
    {
      "id": "ig_32",
      "decision": "ignore",
      "category": "工单列表查询异常",
      "reason": "工单列表与管理页查询异常当前按低优先级业务问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/inner/workOrder/findWorkOrderPageRecord",
          "/admin/workOrder"
        ]
      }
    },
    {
      "id": "ig_33",
      "decision": "ignore",
      "category": "商户理赔统计查询异常",
      "reason": "商户理赔统计查询异常当前按低优先级业务问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/admin/merchantClaim/settleClaimStatistics"
        ]
      }
    },
    {
      "id": "ig_34",
      "decision": "ignore",
      "category": "实名更新员工异常",
      "reason": "实名更新员工失败当前按业务数据问题处理",
      "match": {
        "class": "MemberAuthServiceImpl",
        "method": "updateEmployee",
        "message_contains": [
          "用户实名记录后更新员工失败"
        ]
      }
    },
    {
      "id": "ig_35",
      "decision": "ignore",
      "category": "AES解密失败",
      "reason": "AES 解密失败当前按调用侧或数据问题处理",
      "match": {
        "class": "AESEncryptionUtil",
        "method": "decrypt",
        "message_contains": [
          "AES decryption failed"
        ]
      }
    },
    {
      "id": "ig_36",
      "decision": "ignore",
      "category": "理赔支付参数校验异常",
      "reason": "理赔支付参数校验异常当前按入参问题处理",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleMethodArgumentNotValidException",
        "message_contains": [
          "ASecondReimburseController.add"
        ]
      }
    },
    {
      "id": "ig_37",
      "decision": "ignore",
      "category": "支付查询主订单日志",
      "reason": "支付主订单查询日志误入异常集合，直接忽略",
      "match": {
        "class": "UserOrderServiceImpl",
        "method": "verifyPayMainOrder",
        "message_contains": [
          "支付校验主订单查询主订单信息"
        ]
      }
    },
    {
      "id": "ig_38",
      "decision": "ignore",
      "category": "前端订单查询日志",
      "reason": "前端订单查询日志误入异常集合，直接忽略",
      "match": {
        "class": "UserOrderServiceImpl",
        "method": "getOrderById",
        "message_contains": [
          "查询主订单信息"
        ]
      }
    },
    {
      "id": "ig_39",
      "decision": "ignore",
      "category": "体检员工信息异常",
      "reason": "体检问卷员工信息获取失败当前按业务数据问题处理",
      "match": {
        "class": "HealthPhysicalServiceImpl",
        "method": "addQuestionnaireRecord",
        "message_contains": [
          "获取员工信息失败"
        ]
      }
    },
    {
      "id": "ig_40",
      "decision": "ignore",
      "category": "商品搜索404噪音",
      "reason": "商品搜索404属于错误路径或外部请求噪音，默认忽略",
      "match": {
        "class": "GoodsSearchServiceImpl",
        "method": "goodsSearchResList",
        "message_contains": [
          "No static resource outbiz/goods/search."
        ]
      }
    },
    {
      "id": "ig_41",
      "decision": "ignore",
      "category": "商品搜索编码异常",
      "reason": "商品搜索入参编码异常当前按调用侧问题处理",
      "match": {
        "class": "GoodsSearchServiceImpl",
        "method": "goodsSearchResList",
        "message_contains": [
          "Illegal base64 character 5b"
        ]
      }
    },
    {
      "id": "ig_42",
      "decision": "ignore",
      "category": "商家后台权限拒绝",
      "reason": "商家后台批量账号接口权限拒绝属于账号权限问题",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleAccessDeniedException",
        "message_contains": [
          "/admin/account/batch/",
          "Access Denied"
        ]
      }
    },
    {
      "id": "ig_43",
      "decision": "ignore",
      "category": "系统后台权限拒绝",
      "reason": "系统角色列表权限拒绝属于后台权限问题",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleAccessDeniedException",
        "message_contains": [
          "/admin/role/list",
          "Access Denied"
        ]
      }
    },
    {
      "id": "ig_44",
      "decision": "ignore",
      "category": "订单插入SQL调试日志",
      "reason": "订单插入SQL调试输出不作为异常处理",
      "match": {
        "class": "T.insert",
        "method": "debug",
        "message_contains": [
          "==> Parameters:"
        ]
      }
    },
    {
      "id": "ig_45",
      "decision": "ignore",
      "category": "订单详情查询日志",
      "reason": "订单详情查询日志误入异常集合，直接忽略",
      "match": {
        "class": "BaseManagerImpl",
        "method": "selectById",
        "message_contains": [
          "selectById:TradeOrdersPo("
        ]
      }
    },
    {
      "id": "ig_46",
      "decision": "ignore",
      "category": "订单幂等校验日志",
      "reason": "订单创建幂等校验日志误入异常集合，直接忽略",
      "match": {
        "class": "TradeOrdersServiceImpl",
        "method": "checkIdempotency",
        "message_contains": [
          "提交创建订单-开始进行幂等校验"
        ]
      }
    },
    {
      "id": "ig_47",
      "decision": "ignore",
      "category": "支付链接查询主订单日志",
      "reason": "支付链接生成前查询主订单的INFO日志误入异常集合",
      "match": {
        "class": "UserOrderServiceImpl",
        "method": "linkPayUrl",
        "message_contains": [
          "[linkPayUrl-查询主订单信息]",
          "\"businessFail\":false"
        ]
      }
    },
    {
      "id": "ig_48",
      "decision": "ignore",
      "category": "额度支付拆单开始日志",
      "reason": "额度支付拆单开始处理属于流程日志，不作为异常",
