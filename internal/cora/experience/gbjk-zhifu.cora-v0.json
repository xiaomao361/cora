        "class": "OrderCreateServiceImpl",
        "method": "lambda$validateGoodsList$2",
        "message_contains": [
          "商品编码",
          "信息不存在"
        ]
      }
    },
    {
      "id": "ig_54",
      "decision": "ignore",
      "category": "系统字典类型查询异常",
      "reason": "系统字典类型查询异常属于后台配置查询问题",
      "match": {
        "class": "GlobalExceptionHandler",
        "method": "handleRuntimeException",
        "message_contains": [
          "/admin/dict/type/types/"
        ]
      }
    },
    {
      "id": "ig_55",
      "decision": "ignore",
      "category": "前端换绑人脸手机号异常",
      "reason": "换绑人脸手机号异常偏账号流程问题，默认忽略",
      "match": {
