{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cora.local/schemas/cora-decision.v1.schema.json",
  "title": "Cora Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "category", "rule_id", "reason", "source", "decided_at"],
  "properties": {
    "decision": { "type": "string", "enum": ["attention", "observe", "ignore"] },
    "root_cause_key": { "type": "string" },
    "category": { "type": "string", "minLength": 1 },
    "rule_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "enum": ["experience_pack", "framework_default"] },
    "experience_version": { "type": "string" },
    "trace_role": { "type": "string", "enum": ["unknown", "wrapper", "cause"] },
    "decided_at": { "type": "string", "format": "date-time" }
  }
}
