{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cora.local/schemas/cora-closure-receipt.v1.schema.json",
  "title": "Cora Closure Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "closure_receipt_id",
    "iteration_run_id",
    "product_line",
    "service",
    "fingerprint",
    "case_snapshot",
    "rule",
    "evaluation",
    "deployment",
    "observation",
    "status",
    "retention_eligible",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "cora.closure-receipt.v1" },
    "closure_receipt_id": { "$ref": "#/$defs/stable_id" },
    "iteration_run_id": { "$ref": "#/$defs/stable_id" },
    "product_line": { "$ref": "#/$defs/non_empty" },
    "service": { "$ref": "#/$defs/non_empty" },
    "fingerprint": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "case_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "through_case_id", "case_ids", "manifest_sha256", "verified_at"],
      "properties": {
        "snapshot_id": { "$ref": "#/$defs/non_empty" },
        "through_case_id": { "type": "integer", "minimum": 1 },
        "case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "verified_at": { "type": "string", "format": "date-time" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "rule_id", "pack_version", "pack_sha256", "approved_at"],
      "properties": {
        "candidate_id": { "$ref": "#/$defs/stable_id" },
        "rule_id": { "$ref": "#/$defs/non_empty" },
        "pack_version": { "$ref": "#/$defs/non_empty" },
        "pack_sha256": { "$ref": "#/$defs/sha256" },
        "approved_at": { "type": "string", "format": "date-time" }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eval_run_id", "status", "artifact_sha256"],
      "properties": {
        "eval_run_id": { "$ref": "#/$defs/stable_id" },
        "status": { "type": "string", "enum": ["passed", "failed"] },
        "artifact_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["not_deployed", "deployed", "rolled_back"] },
        "build_version": { "$ref": "#/$defs/non_empty" },
        "build_commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
        "deployed_at": { "type": "string", "format": "date-time" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ends_at"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "passed", "failed"] },
        "ends_at": { "type": "string", "format": "date-time" },
        "validated_at": { "type": "string", "format": "date-time" },
        "evidence_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "status": { "type": "string", "enum": ["open", "validated", "rolled_back"] },
    "retention_eligible": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "retention_eligible": { "const": true } }, "required": ["retention_eligible"] },
      "then": {
        "properties": {
          "status": { "const": "validated" },
          "evaluation": {
            "properties": { "status": { "const": "passed" } },
            "required": ["status"]
          },
          "deployment": {
            "properties": { "status": { "const": "deployed" } },
            "required": ["status", "build_version", "build_commit", "deployed_at"]
          },
          "observation": {
            "properties": { "status": { "const": "passed" } },
            "required": ["status", "validated_at", "evidence_sha256"]
          }
        }
      }
    }
  ],
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "stable_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
